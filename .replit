modules = ["nodejs-24", "python3", "python-3.12"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "install"
mode = "sequential"
author = 56718866

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow]]
name = "keep live"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bot && bash keep_alive.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "push"
mode = "sequential"
author = 56718866

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git config --global user.name \"salihamadah60\" git config --global user.email \"salih@gmail.com\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git config --global user.email \"salih@gmail.com\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git init"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git add ."

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["openssl"]

[[ports]]
localPort = 8080
